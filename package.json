{
  "name": "skitterspec-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "skitterspec workspaces — the base spec-driven workflow plus swappable ticketing-provider packages.",
  "license": "MIT",
  "author": "Reuben Greaves",
  "type": "commonjs",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@skitterbyte/skittership": "^1.0.0"
  },
  "scripts": {
    "test": "node --test",
    "build": "node scripts/build-dist.js all",
    "release": "node scripts/release.js",
    "preversion": "node scripts/no-root-version.js",
    "publish:base": "node scripts/release.js skitterspec 2.0.1 --publish",
    "publish:linear": "node scripts/release.js skitterspec-linear 1.0.0 --publish",
    "publish:all": "npm run publish:base && npm run publish:linear"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skitterbyte/skitterspec.git"
  }
}
