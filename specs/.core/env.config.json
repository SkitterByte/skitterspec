{
  "worktree": {
    "root": "../{repo}-wt",
    "folderPattern": "{slug}"
  },
  "docker": {
    "enabled": false,
    "composeFile": "docker-compose.yml",
    "projectNamePattern": "{repoSlug}_{slug}",
    "portBase": 3000,
    "portsPerSpec": 10,
    "envFile": ".env",
    "backupCommand": ""
  },
  "open": {
    "command": "open -a Warp {worktreePath}"
  },
  "registry": ".spec-env/registry.json",
  "linkLinear": false,
  "guards": {
    "refuseTeardownIfDirty": true,
    "refuseTeardownIfUnpushed": true
  }
}
