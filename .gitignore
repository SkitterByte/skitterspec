node_modules/
*.log
.DS_Store
/tmp/

# Built distributions: bin/src/assets are composed from the private packages by
# scripts/build-dist.js (at prepack / test time). Only each dist's package.json
# and README are committed.
/packages/skitterspec/assets/
/packages/skitterspec/bin/
/packages/skitterspec/src/
/packages/skitterspec-linear/assets/
/packages/skitterspec-linear/bin/
/packages/skitterspec-linear/src/

# Per-spec isolation: machine-local slot registry + volume backups (never committed)
/.spec-env/

# Linear hybrid sync: --force backups are local recovery (the base sidecars under
# specs/.core/linear-base/ ARE committed — each worktree carries its own base)
specs/.core/linear-backups/

# Local-only Claude Code settings (dog-fooding: skills/rules are symlinked from assets/)
.claude/settings.local.json
